# Public uploads are static assets only.
Options -Indexes -ExecCGI -Includes

# Remove common executable handlers inherited from the server configuration.
<IfModule mod_mime.c>
    RemoveHandler .php .php3 .php4 .php5 .php7 .php8 .phtml .phar .cgi .pl .py .rb .sh .shtml
    RemoveType .php .php3 .php4 .php5 .php7 .php8 .phtml .phar .cgi .pl .py .rb .sh .shtml
</IfModule>

# Fail closed for executable, configuration, archive, database, backup, and
# unmanaged HTML content inside the upload tree.
<FilesMatch "\.(?:php[0-9]?|phtml|phar|cgi|pl|py|rb|sh|shtml|htm|html|env|ini|conf|config|log|sql|sqlite|bak|backup|old|orig|save|swp|zip|tar|gz|tgz|rar|7z)$">
    Require all denied
</FilesMatch>
